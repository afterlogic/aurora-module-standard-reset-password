#!/bin/bash

PROJECT=`php -r "echo dirname(dirname(realpath('$0')));"`
STAGED_FILES_CMD=`git diff --name-only --diff-filter=ACMR HEAD | grep "\.php$"`

# Determine if a file list is passed
if [ "$#" -eq 1 ]
then
    oIFS=$IFS
    IFS='
    '
    SFILES="$1"
    IFS=$oIFS
fi
SFILES=${SFILES:-$STAGED_FILES_CMD}

echo "Checking PHP files..."

for FILE in $SFILES
do
    php -l -d display_errors=0 $PROJECT/$FILE
    if [ $? != 0 ]
    then
        printf "Fix syntax errors before commit."
        exit 1
    fi
    FILES="$FILES $PROJECT/$FILE"
done

PHPSTAN="../../vendor/bin/phpstan"

if [ -f "$PHPSTAN" ]; then
    echo ""
    printf "Running PhpStan..."
	eval "$PHPSTAN analyze --level 2 --configuration ../../phpstan.neon --no-progress ./"
    if [ $? != 0 ]
    then
        echo "Fix PhpStan errors before commit."
        echo "Run: '$PHPSTAN analyze'"
        exit 1
    fi
fi

CSFIXER="../../php-cs-fixer.phar"

if [ -f "$CSFIXER" ]; then
    echo ""
    echo "Running CS Fixer..."

    eval "php $CSFIXER fix ./ --rules=@PER --dry-run --using-cache=no"

    if [ $? != 0 ]
    then
        echo "Fix formatting issues before commit."
        echo "Run: 'php $CSFIXER fix ./ --rules=@PER --using-cache=no'"
        exit 1
    fi
fi


# --- unit tests (vitest) ---
UNIT_DIR="$PROJECT/vue-mobile/test/unit"
if [ -d "$UNIT_DIR" ]; then
    STAGED_VUE=`git diff --name-only --diff-filter=ACMR HEAD | grep -E '^vue-mobile/' || true`
    if [ -n "$STAGED_VUE" ]; then
        echo ""
        echo "Running unit tests (vue-mobile)..."
        if [ ! -d "$PROJECT/vue-mobile/node_modules" ]; then
            echo "vue-mobile/node_modules missing. Run: cd vue-mobile && yarn"
            exit 1
        fi
        (cd "$PROJECT/vue-mobile" && yarn test:unit)
        if [ $? != 0 ]; then
            echo "Fix unit test failures before commit."
            echo "Run: 'cd vue-mobile && yarn test:unit'"
            exit 1
        fi
    fi
fi
# --- end unit tests (vitest) ---

exit 0
